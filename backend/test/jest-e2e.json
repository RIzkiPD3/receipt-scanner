{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^puppeteer$": "<rootDir>/../src/__mocks__/puppeteer.ts",
    "\\.\\./generated/prisma/client(\\.js)?$": "<rootDir>/../src/__mocks__/prisma-client.ts",
    ".*/generated/prisma/client(\\.js)?$": "<rootDir>/../src/__mocks__/prisma-client.ts",
    "^@prisma/adapter-pg$": "<rootDir>/../src/__mocks__/prisma-adapter-pg.ts"
  }
}
