# =============================================================================
# InvoiceGo Backend — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (Individual variables — used for documentation)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=invoicego

# -----------------------------------------------------------------------------
# DATABASE_URL — Required by Prisma
# -----------------------------------------------------------------------------
# Prisma uses a single connection string (DSN) instead of individual DB_* vars.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Update USER, PASSWORD, HOST, PORT, and DATABASE to match your environment.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# -----------------------------------------------------------------------------
# WhatsApp Cloud API
# -----------------------------------------------------------------------------
WHATSAPP_VERIFY_TOKEN=your_super_secret_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# -----------------------------------------------------------------------------
# Worker Service Configuration
# -----------------------------------------------------------------------------
WORKER_SERVICE_URL=http://localhost:8080
