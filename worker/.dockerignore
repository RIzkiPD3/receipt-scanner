# ── Go build output ───────────────────────────────────────────────────────────
*.exe
*.exe~
worker
worker.exe

# ── Temp directories (re-created at runtime) ──────────────────────────────────
temp/

# ── Secrets & local env ───────────────────────────────────────────────────────
.env
.env.*
*.local

# ── Tests (not needed at runtime) ────────────────────────────────────────────
**/*_test.go

# ── Git & IDE ─────────────────────────────────────────────────────────────────
.git/
.gitignore
.vscode/
.idea/

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
