# App Configuration
PORT=8080
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=invoicego

# OCR & AI Services
# E.g., OCR_API_KEY, OPENAI_API_KEY, or Google Gemini API Key
AI_SERVICE_API_KEY=your_ai_api_key_here
AI_MODEL_NAME=gemini-1.5-flash

# NestJS Backend Callback Configuration
BACKEND_CALLBACK_URL=http://localhost:3000/api/v1/receipts/callback

# OCR Configuration
# Path ke executable tesseract. Jika ada di PATH sistem, gunakan "tesseract"
TESSERACT_PATH=tesseract
TEMP_DOWNLOAD_DIR=temp/downloads
