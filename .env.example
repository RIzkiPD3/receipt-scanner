# =============================================================================
# InvoiceGo — Root Environment Variables
# =============================================================================
# Salin file ini ke .env dan isi nilai yang sesuai:
#   cp .env.example .env
#
# File .env ini digunakan oleh docker-compose.yml untuk semua service.
# JANGAN commit file .env ke version control.
# =============================================================================

# =============================================================================
# Docker Compose Project
# =============================================================================
COMPOSE_PROJECT_NAME=invoicego

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=invoicego
POSTGRES_USER=invoicego
POSTGRES_PASSWORD=ganti_dengan_password_aman

# =============================================================================
# Backend (NestJS) — port 3000
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT akan di-override ke 3000 di docker-compose.yml

# ── Database ─────────────────────────────────────────────────────────────────
# Saat Docker: @postgres = nama service di docker-compose.yml
# Saat lokal (tanpa Docker): ganti @postgres dengan @localhost
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=invoicego
DB_PASSWORD=ganti_dengan_password_aman
DB_DATABASE=invoicego
DATABASE_URL=postgresql://invoicego:ganti_dengan_password_aman@postgres:5432/invoicego?schema=public

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Dapatkan dari https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=token_verifikasi_rahasia_anda
WHATSAPP_ACCESS_TOKEN=token_akses_whatsapp_cloud_api
WHATSAPP_PHONE_NUMBER_ID=id_nomor_telepon_whatsapp

# ── Worker Client ─────────────────────────────────────────────────────────────
# Saat Docker: worker = nama service di docker-compose.yml
WORKER_SERVICE_URL=http://worker:8080
WORKER_TIMEOUT_MS=30000
WORKER_MAX_RETRIES=3

# ── Application URL (untuk static asset) ─────────────────────────────────────
APP_URL=http://localhost:3000

# ── Temporary Directories ─────────────────────────────────────────────────────
TEMP_UPLOAD_DIR=temp/uploads

# =============================================================================
# Worker (Golang + Tesseract OCR) — port 8080
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
# PORT dan ENV akan di-override di docker-compose.yml

# ── OCR ──────────────────────────────────────────────────────────────────────
# Di dalam Docker: `tesseract` sudah tersedia di PATH sistem
TESSERACT_PATH=tesseract
TEMP_DOWNLOAD_DIR=temp/downloads

# ── Backend callback (dari Worker ke Backend) ──────────────────────────────────
# Saat Docker: backend = nama service di docker-compose.yml
BACKEND_CALLBACK_URL=http://backend:3000/api/v1/receipts/callback
BACKEND_API_URL=http://backend:3000

# ── NVIDIA Nemotron AI (opsional — untuk ekstraksi data struk) ────────────────
NVIDIA_API_KEY=kunci_api_nvidia_anda
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# ── AI Service (opsional — alternatif) ───────────────────────────────────────
AI_SERVICE_API_KEY=kunci_api_ai_anda
AI_MODEL_NAME=gemini-1.5-flash
